{
  "name": "nestjs-apcore",
  "version": "0.3.1",
  "description": "NestJS adapter for the apcore AI-Perceivable module ecosystem",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10.0.0",
    "@nestjs/core": ">=10.0.0",
    "apcore-mcp": "^0.10.0",
    "reflect-metadata": ">=0.1.13",
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "class-validator": {
      "optional": true
    },
    "class-transformer": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "apcore-mcp": {
      "optional": true
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "apcore-js": "^0.13.0",
    "apcore-toolkit": "^0.2.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@sinclair/typebox": "^0.34.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "apcore-mcp": "^0.10.0",
    "apdev-js": "^0.2.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0",
    "zod": "^3.23.0"
  },
  "keywords": [
    "nestjs",
    "apcore",
    "mcp",
    "model-context-protocol",
    "ai",
    "ai-tools",
    "llm",
    "openai",
    "tool-calling",
    "nestjs-module",
    "decorator",
    "typescript"
  ],
  "author": "aipartnerup",
  "homepage": "https://github.com/aipartnerup/nestjs-apcore#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/aipartnerup/nestjs-apcore.git"
  },
  "bugs": {
    "url": "https://github.com/aipartnerup/nestjs-apcore/issues"
  },
  "license": "Apache-2.0",
  "apdev": {
    "base_package": "nestjs-apcore"
  }
}